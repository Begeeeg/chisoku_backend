{
    "compilerOptions": {
        "rootDir": "./src",
        "outDir": "./dist",

        "target": "ESNext",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,

        "strict": true,
        "skipLibCheck": true,

        "types": ["jest", "node"],
        "resolveJsonModule": true,

        "sourceMap": true
    },
    "include": ["src", "src/types", "tests"],
    "exclude": ["node_modules", "dist"]
}
